import "../main.nari";

func build_cli() {
  let program = create_command("pizza");
  program
    .name("pizza")
    .description("Pizza order CLI")
    .version("1.2.0")
    .option("-p, --peppers <type>", "Add peppers")
    .option("-c, --cheese [type]", "Add cheese with optional type", "mozzarella")
    .option("-v, --verbose", "verbose output")
    .required_option("-s, --size <size>", "pizza size")
    .add_option(create_option("-d, --drink <drink>", "drink choice").choices(["coke", "pepsi", "water"]))
    .argument("[count]", "number of pizzas", "1")
    .action(func(count, options) {
      print("order: " @ count @ " " @ options.size @ " pizzas");
      print("cheese:", options.cheese);
      print("peppers:", options.peppers);
      print("drink:", options.drink);
      print("verbose:", options.verbose);
    });
  return program;
}

print("=== help info ===");
let p = build_cli();
print(p.help_information({}));

print("=== version ===");
print("version:", p.version());

print("=== valid order ===");
let p2 = build_cli();
p2.parse(["--size", "large", "-d", "coke", "--peppers", "jalapeno", "3"], { from: "user" });
